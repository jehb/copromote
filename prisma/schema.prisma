generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String          @id @default(uuid())
  name        String
  description String?         @db.Text
  status      String          @default("Active")
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  assets      Asset[]
  events      CalendarEvent[]
  createdBy   User?           @relation("ProjectCreator", fields: [createdById], references: [id])
  updatedBy   User?           @relation("ProjectUpdater", fields: [updatedById], references: [id])
  tasks       Task[]

  @@index([createdById], map: "Project_createdById_fkey")
  @@index([updatedById], map: "Project_updatedById_fkey")
}

model Asset {
  id                String           @id @default(uuid())
  name              String
  type              String
  url               String
  projectId         String?
  promotionPeriodId String?
  socialPostId      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  project           Project?         @relation(fields: [projectId], references: [id])
  promotionPeriod   PromotionPeriod? @relation(fields: [promotionPeriodId], references: [id])
  socialPost        SocialPost?      @relation(fields: [socialPostId], references: [id])

  @@index([projectId], map: "Asset_projectId_fkey")
  @@index([promotionPeriodId], map: "Asset_promotionPeriodId_fkey")
  @@index([socialPostId], map: "Asset_socialPostId_fkey")
}

model AssetTemplate {
  id           String   @id @default(uuid())
  name         String
  elements     Json
  canvasSize   Json
  canvasBg     String
  previewImage String?  @db.LongText
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SavedAsset {
  id           String      @id @default(uuid())
  name         String
  category     String
  elements     Json
  canvasSize   Json
  canvasBg     String
  previewImage String?     @db.LongText
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  emailItems   EmailItem[]
}

model CalendarEvent {
  id        String   @id @default(uuid())
  title     String
  date      DateTime
  type      String
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  project   Project? @relation(fields: [projectId], references: [id])

  @@index([projectId], map: "CalendarEvent_projectId_fkey")
}

model PromotionPeriod {
  id                   String       @id @default(uuid())
  name                 String
  startDate            DateTime
  endDate              DateTime
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  adImageDeadline      DateTime?
  adLiveDate           DateTime?
  adPublishingDeadline DateTime?
  assets               Asset[]
  posts                SocialPost[]
}

model SocialPost {
  id                String           @id @default(uuid())
  content           String           @db.Text
  platform          String
  scheduledDate     DateTime?
  status            String           @default("draft")
  postizId          String?
  promotionPeriodId String?
  reviewerId        String?
  eventId           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?
  assets            Asset[]
  event             Event?           @relation(fields: [eventId], references: [id])
  promotionPeriod   PromotionPeriod? @relation(fields: [promotionPeriodId], references: [id])
  reviewer          User?            @relation("PostReviewer", fields: [reviewerId], references: [id])

  @@index([eventId], map: "SocialPost_eventId_fkey")
  @@index([promotionPeriodId], map: "SocialPost_promotionPeriodId_fkey")
  @@index([reviewerId], map: "SocialPost_reviewerId_fkey")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model User {
  id                   String         @id @default(uuid())
  name                 String
  email                String         @unique
  username             String         @unique @default("admin")
  password             String         @default("$2a$10$......................")
  role                 String         @default("USER")
  roleRecord           Role?          @relation(fields: [role], references: [name])
  mustChangePassword   Boolean        @default(true)
  avatar               String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  contactId            String?        @unique
  activityLogs         ActivityLog[]
  createdContacts      Contact[]      @relation("ContactCreator")
  updatedContacts      Contact[]      @relation("ContactUpdater")
  createdEvents        Event[]        @relation("EventCreator")
  events               Event[]
  updatedEvents        Event[]        @relation("EventUpdater")
  createdOrganizations Organization[] @relation("OrganizationCreator")
  updatedOrganizations Organization[] @relation("OrganizationUpdater")
  createdProjects      Project[]      @relation("ProjectCreator")
  updatedProjects      Project[]      @relation("ProjectUpdater")
  SecurityLog          SecurityLog[]
  reviewedPosts        SocialPost[]   @relation("PostReviewer")
  tasks                Task[]
  createdTasks         Task[]         @relation("TaskCreator")
  updatedTasks         Task[]         @relation("TaskUpdater")
  contact              Contact?       @relation(fields: [contactId], references: [id])
  apiKeys              ApiKey[]
  twoFactorChallenge   TwoFactorChallenge?
}

model Event {
  id               String         @id @default(uuid())
  title            String
  description      String?        @db.Text
  internalNotes    String?        @db.Text
  startTime        DateTime
  endTime          DateTime
  status           EventStatus    @default(SCHEDULED)
  locationId       String
  primaryContactId String?
  seriesId         String?
  wordpressId      Int?
  wordpressUrl     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  createdById      String?
  updatedById      String?
  createdBy        User?          @relation("EventCreator", fields: [createdById], references: [id])
  location         Location       @relation(fields: [locationId], references: [id])
  primaryContact   User?          @relation(fields: [primaryContactId], references: [id])
  series           EventSeries?   @relation(fields: [seriesId], references: [id])
  updatedBy        User?          @relation("EventUpdater", fields: [updatedById], references: [id])
  socialPosts      SocialPost[]
  contacts         Contact[]      @relation("EventContacts")
  organizations    Organization[] @relation("EventOrganizations")
  emailItems       EmailItem[]    @relation("EmailItemEvents")
  products         EventProduct[]

  @@index([createdById], map: "Event_createdById_fkey")
  @@index([locationId], map: "Event_locationId_fkey")
  @@index([primaryContactId], map: "Event_primaryContactId_fkey")
  @@index([seriesId], map: "Event_seriesId_fkey")
  @@index([updatedById], map: "Event_updatedById_fkey")
}

model EventProduct {
  id        String   @id @default(uuid())
  upc       String
  eventId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, upc])
  @@index([eventId], map: "EventProduct_eventId_fkey")
}

model EventSeries {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  status      String    @default("todo")
  dueDate     DateTime?
  assigneeId  String?
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  createdBy   User?     @relation("TaskCreator", fields: [createdById], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  updatedBy   User?     @relation("TaskUpdater", fields: [updatedById], references: [id])

  @@index([assigneeId], map: "Task_assigneeId_fkey")
  @@index([createdById], map: "Task_createdById_fkey")
  @@index([projectId], map: "Task_projectId_fkey")
  @@index([updatedById], map: "Task_updatedById_fkey")
}

model Location {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Config {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id             String        @id @default(uuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  company        String?
  jobTitle       String?
  notes          String?       @db.Text
  type           String
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?
  createdBy      User?         @relation("ContactCreator", fields: [createdById], references: [id])
  organization   Organization? @relation("OrganizationContacts", fields: [organizationId], references: [id])
  updatedBy      User?         @relation("ContactUpdater", fields: [updatedById], references: [id])
  primaryFor     Organization? @relation("PrimaryContact")
  user           User?
  events         Event[]       @relation("EventContacts")

  @@index([createdById], map: "Contact_createdById_fkey")
  @@index([organizationId], map: "Contact_organizationId_fkey")
  @@index([updatedById], map: "Contact_updatedById_fkey")
}

model Organization {
  id               String    @id @default(uuid())
  name             String
  category         String
  description      String?   @db.Text
  website          String?
  externalBrand    String?
  primaryContactId String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  createdById      String?
  updatedById      String?
  contacts         Contact[] @relation("OrganizationContacts")
  createdBy        User?     @relation("OrganizationCreator", fields: [createdById], references: [id])
  primaryContact   Contact?  @relation("PrimaryContact", fields: [primaryContactId], references: [id])
  updatedBy        User?     @relation("OrganizationUpdater", fields: [updatedById], references: [id])
  events           Event[]   @relation("EventOrganizations")

  @@index([createdById], map: "Organization_createdById_fkey")
  @@index([updatedById], map: "Organization_updatedById_fkey")
}

model SecurityLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId], map: "SecurityLog_userId_fkey")
}

model ActivityLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?
  details    String?  @db.Text
  metadata   String?
  userId     String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId], map: "ActivityLog_userId_fkey")
}

model Hyperlink {
  id          String   @id @default(uuid())
  url         String
  title       String
  description String?  @db.Text
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MagicLink {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expires   DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  usedAt    DateTime?
}

model EmailPlan {
  id        String      @id @default(uuid())
  subject   String
  sendDate  DateTime
  notes     String?     @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     EmailItem[]
}

model EmailItem {
  id           String             @id @default(uuid())
  title        String
  description  String?            @db.Text
  planId       String
  order        Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  plan         EmailPlan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  events       Event[]            @relation("EmailItemEvents")
  products     EmailItemProduct[]
  savedAssetId String?
  savedAsset   SavedAsset?        @relation(fields: [savedAssetId], references: [id], onDelete: SetNull)
  photos       EmailItemPhoto[]

  @@index([planId], map: "EmailItem_planId_fkey")
  @@index([savedAssetId], map: "EmailItem_savedAssetId_fkey")
}

model RolePermission {
  id         String   @id @default(uuid())
  role       String
  page       String
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  roleRecord Role?    @relation(fields: [role], references: [name], onDelete: Cascade)

  @@unique([role, page])
  @@index([role], map: "RolePermission_role_fkey")
}

model EmailItemPhoto {
  id        String    @id @default(uuid())
  photoId   String
  itemId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  item      EmailItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, photoId])
  @@index([itemId], map: "EmailItemPhoto_itemId_fkey")
}

model EmailItemProduct {
  id        String    @id @default(uuid())
  upc       String
  itemId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  item      EmailItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, upc])
  @@index([itemId], map: "EmailItemProduct_itemId_fkey")
}

enum EventStatus {
  TENTATIVE
  SCHEDULED
  PAST
  CANCELED
}

model ColorPalette {
  id        String   @id @default(uuid())
  name      String   @unique
  colors    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  key        String    @unique
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "ApiKey_userId_fkey")
}

model Theme {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  isRecurring Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  parentId    String?
  parent      Theme?   @relation("ThemeToTheme", fields: [parentId], references: [id])
  children    Theme[]  @relation("ThemeToTheme")

  @@index([parentId], map: "Theme_parentId_fkey")
}

model WhitelistedIp {
  id          String   @id @default(uuid())
  ipAddress   String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TwoFactorChallenge {
  id        String   @id @default(uuid())
  code      String
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

